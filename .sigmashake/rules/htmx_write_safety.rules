# htmx_write_safety.rules
# Technology: htmx | Capability: write

rule htmx-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_htmx_PATTERN"
  MESSAGE "Blocked an unsafe pattern in htmx. Use the recommended best practices for 2025/2026."
}

rule htmx-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_htmx_API"
  MESSAGE "You are using an outdated API for htmx. Please upgrade to the newer API."
}
